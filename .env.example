# Community Guardian — Environment Variables
# Copy this file to .env.local and fill in your values.

# AI Provider: "anthropic" | "rules" (default: "rules")
# When set to "rules", the app uses deterministic rule-based classification.
# No API key is needed for rule-based mode.
AI_PROVIDER=rules

# Anthropic (only needed if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# App
NODE_ENV=development
